---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import PaperAirplane from '../components/PaperAirplane.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  page?: string;
}

const {
  title       = 'Ethan S. Hammel — Portfolio',
  description = 'IT student, technical support specialist, and creative. Portfolio and résumé.',
  ogImage     = '/og-default.svg',
  page        = '',
} = Astro.props;

const year = new Date().getFullYear();

// ── Site-wide config — edit these constants ───────────────────
const BRAND_NAME    = 'Ethan Hammel';
const CONTACT_EMAIL = 'ethan.s.hammel@gmail.com';
const GITHUB_URL    = 'https://github.com/ethanhammel';       // update if different
const LINKEDIN_URL  = 'https://linkedin.com/in/ethanhammel';  // update if different
// ─────────────────────────────────────────────────────────────
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:type"        content="website" />
  <meta name="twitter:card"       content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <slot name="head" />
</head>
<body>

  <PaperAirplane />

  <!-- Tree border — fixed to right edge, tiles vertically, hidden on mobile -->
  <div class="tree-border" aria-hidden="true"></div>

  <Nav page={page} brandName={BRAND_NAME} contactEmail={CONTACT_EMAIL} />

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">

      <div class="site-footer__col">
        <span class="site-footer__brand-name">{BRAND_NAME}</span>
        <span class="site-footer__brand-sub">© {year} — All rights reserved</span>
      </div>

      <div class="site-footer__col">
        <span class="site-footer__col-label">Pages</span>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/resume">Résumé</a></li>
          <li><a href="/art">Art</a></li>
          <li><a href="/interactive">Interactive</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <span class="site-footer__col-label">Elsewhere</span>
        <ul>
          <li><a href={GITHUB_URL}   target="_blank" rel="noopener">GitHub</a></li>
          <li><a href={LINKEDIN_URL} target="_blank" rel="noopener">LinkedIn</a></li>
          <li><a href={`mailto:${CONTACT_EMAIL}`}>Email</a></li>
        </ul>
      </div>

    </div>
  </footer>

  <!-- Keyword tooltip: mobile tap-to-open -->
  <script>
    document.querySelectorAll('.kw').forEach(kw => {
      kw.addEventListener('click', () => {
        if (window.innerWidth < 640) {
          document.querySelectorAll('.kw').forEach(k => {
            if (k !== kw) k.classList.remove('kw--active');
          });
          kw.classList.toggle('kw--active');
        }
      });
    });
    document.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('.kw')) {
        document.querySelectorAll('.kw').forEach(k => k.classList.remove('kw--active'));
      }
    });
  </script>

</body>
</html>

<style is:global>
.chip--active {
  background: rgba(74,124,63,0.1);
  border-color: var(--moss);
  color: var(--moss-dark);
}
.kw--active .kw-panel { opacity: 1 !important; }

/* ── Tree border ────────────────────────────────────────────── */
/* Image is 70×500px. Fixed to right edge, tiles vertically.    */
/* z-index 50 — above page content, below nav (100) and bird.   */
.tree-border {
  position: fixed;
  bottom: 0;
  right: 10px;
  width: 200px;
  height: 794px;
  background-image: url('/tree.png');
  background-repeat: no-repeat;
  background-position: center bottom;
  background-size: 200px 794px;
  pointer-events: none;
  z-index: 50;
}

/* Hide on mobile — not enough screen width */
@media (max-width: 900px) {
  .tree-border { display: none; }
}
</style>
