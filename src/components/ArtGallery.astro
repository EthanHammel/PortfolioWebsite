---
// src/components/ArtGallery.astro
// Single-image slideshow. Accepts galleryId so multiple galleries
// on the same page (one per project folder) don't conflict.

export interface GalleryItem {
  src: string; filename: string; ext: string; isGif: boolean; path: string;
}
export interface Props {
  items:     GalleryItem[];
  galleryId?: string;   // unique id prefix, default "gallery-0"
}

const { items, galleryId = 'gallery-0' } = Astro.props;
const count    = items.length;
const itemsJson = JSON.stringify(items.map(i => ({
  src: i.src, filename: i.filename, ext: i.ext, isGif: i.isGif,
})));
const useDots = count <= 20;
const id = galleryId; // short alias
---

{count > 0 ? (
  <div class="slideshow" aria-label="Gallery">

    <div class="slideshow__stage" data-stage>

      <button class="slideshow__arrow slideshow__arrow--prev" data-prev aria-label="Previous">‹</button>

      <img
        class="slideshow__img"
        data-img
        src={items[0].src}
        alt={items[0].filename.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ')}
        decoding="async"
      />

      <div class="slideshow__loader" data-loader aria-hidden="true">
        <span class="slideshow__loader-dot"></span>
        <span class="slideshow__loader-dot"></span>
        <span class="slideshow__loader-dot"></span>
      </div>

      <div class="slideshow__meta">
        <span class="slideshow__filename" data-filename>{items[0].filename}</span>
        <span class="slideshow__ext" data-ext>
          {items[0].ext.toUpperCase()}{items[0].isGif ? ' · animated' : ''}
        </span>
      </div>

      <button class="slideshow__arrow slideshow__arrow--next" data-next aria-label="Next">›</button>
    </div>

    <div class="slideshow__bar">
      <span class="slideshow__counter" data-counter>1 / {count}</span>

      {useDots ? (
        <div class="slideshow__dots" role="tablist">
          {items.map((_, i) => (
            <button
              class={`slideshow__dot${i === 0 ? ' is-active' : ''}`}
              data-dot={i}
              role="tab"
              aria-label={`Image ${i + 1}`}
              aria-selected={i === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
      ) : (
        <div class="slideshow__progress">
          <div class="slideshow__progress-fill" data-progress
               style={`width:${(1/count*100).toFixed(2)}%`}></div>
        </div>
      )}

      <span class="slideshow__hint" aria-hidden="true">← → keys</span>
    </div>

  </div>
) : (
  <div class="gallery-empty">
    <p>Nothing here yet.</p>
    <small>Drop images into <code>/public/art/</code> and rebuild.</small>
  </div>
)}

<script define:vars={{ itemsJson, count, useDots }}>
(function () {
  // Find the closest slideshow ancestor of this script's sibling elements.
  // Because Astro hoists scripts, we find the LAST un-initialized slideshow.
  const allSlideshows = document.querySelectorAll('.slideshow:not([data-init])');
  const root = allSlideshows[allSlideshows.length - 1];
  if (!root) return;
  root.setAttribute('data-init', '1');

  const items   = JSON.parse(itemsJson);
  if (!items.length) return;

  const img      = root.querySelector('[data-img]');
  const loader   = root.querySelector('[data-loader]');
  const fname    = root.querySelector('[data-filename]');
  const ext      = root.querySelector('[data-ext]');
  const counter  = root.querySelector('[data-counter]');
  const prev     = root.querySelector('[data-prev]');
  const next     = root.querySelector('[data-next]');
  const stage    = root.querySelector('[data-stage]');
  const dots     = useDots ? Array.from(root.querySelectorAll('[data-dot]')) : null;
  const progress = !useDots ? root.querySelector('[data-progress]') : null;

  let current = 0;
  let loading = false;

  function goTo(idx) {
    if (loading) return;
    if (idx < 0) idx = count - 1;
    if (idx >= count) idx = 0;

    const item = items[idx];
    loading = true;
    img.classList.add('is-loading');
    loader.classList.add('is-visible');

    // Clear GIF before loading next (stops decode, frees memory)
    img.src = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7';

    setTimeout(() => {
      const tmp = new Image();
      tmp.onload = () => {
        img.src = tmp.src;
        img.alt = item.filename.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ');
        img.classList.remove('is-loading');
        loader.classList.remove('is-visible');
        fname.textContent = item.filename;
        ext.textContent   = item.ext.toUpperCase() + (item.isGif ? ' · animated' : '');
        counter.textContent = `${idx + 1} / ${count}`;

        if (dots) {
          dots[current]?.classList.remove('is-active');
          dots[current]?.setAttribute('aria-selected', 'false');
          dots[idx]?.classList.add('is-active');
          dots[idx]?.setAttribute('aria-selected', 'true');
        }
        if (progress) progress.style.width = `${((idx+1)/count*100).toFixed(2)}%`;

        current = idx;
        loading = false;
      };
      tmp.onerror = () => { img.classList.remove('is-loading'); loader.classList.remove('is-visible'); loading = false; };
      tmp.src = item.src;
    }, 40);
  }

  prev?.addEventListener('click', () => goTo(current - 1));
  next?.addEventListener('click', () => goTo(current + 1));
  dots?.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

  // Keyboard: only respond when this slideshow is in view
  document.addEventListener('keydown', e => {
    const r = root.getBoundingClientRect();
    if (r.bottom < 0 || r.top > window.innerHeight) return;
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowLeft')  goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });

  // Touch swipe
  let tx = 0;
  stage?.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
  stage?.addEventListener('touchend',   e => {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) > 40) dx < 0 ? goTo(current + 1) : goTo(current - 1);
  }, { passive: true });

  // Mobile meta overlay on tap
  stage?.addEventListener('click', e => {
    if (window.innerWidth < 640 && !(e.target).closest('.slideshow__arrow')) {
      stage.classList.toggle('meta-open');
    }
  });
})();
</script>
