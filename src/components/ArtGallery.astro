---
// src/components/ArtGallery.astro
// Single-image slideshow with dot/progress indicators and prev/next arrows.
// Only ONE image is in the DOM at a time — GIFs don't pile up and lag.
// Images are loaded on demand when navigating; previous src is cleared first.

export interface GalleryItem {
  src:      string;
  filename: string;
  ext:      string;
  isGif:    boolean;
  path:     string;
}

export interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
const count = items.length;
// Serialize item data for the client script
const itemsJson = JSON.stringify(items.map(i => ({
  src:      i.src,
  filename: i.filename,
  ext:      i.ext,
  isGif:    i.isGif,
})));
// Use dots for ≤ 20 items, progress bar for more
const useDots = count <= 20;
---

{count > 0 ? (
  <div class="slideshow" id="slideshow" aria-label="Art gallery">

    <!-- Image stage -->
    <div class="slideshow__stage" id="ss-stage">

      <!-- Prev arrow -->
      <button class="slideshow__arrow slideshow__arrow--prev"
              id="ss-prev" aria-label="Previous image">‹</button>

      <!-- Single image — src swapped by JS -->
      <img
        class="slideshow__img"
        id="ss-img"
        src={items[0].src}
        alt={items[0].filename.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ')}
        decoding="async"
      />

      <!-- Loading indicator -->
      <div class="slideshow__loader" id="ss-loader" aria-hidden="true">
        <span class="slideshow__loader-dot"></span>
        <span class="slideshow__loader-dot"></span>
        <span class="slideshow__loader-dot"></span>
      </div>

      <!-- Metadata overlay -->
      <div class="slideshow__meta" id="ss-meta">
        <span class="slideshow__filename" id="ss-filename">{items[0].filename}</span>
        <span class="slideshow__ext" id="ss-ext">
          {items[0].ext.toUpperCase()}{items[0].isGif ? ' · animated' : ''}
        </span>
      </div>

      <!-- Next arrow -->
      <button class="slideshow__arrow slideshow__arrow--next"
              id="ss-next" aria-label="Next image">›</button>
    </div>

    <!-- Bottom bar -->
    <div class="slideshow__bar">

      <!-- Counter e.g. "3 / 12" -->
      <span class="slideshow__counter" id="ss-counter">
        1 / {count}
      </span>

      <!-- Dot indicators (≤ 20 images) or progress bar (> 20) -->
      {useDots ? (
        <div class="slideshow__dots" id="ss-dots" role="tablist" aria-label="Go to image">
          {items.map((_, i) => (
            <button
              class={`slideshow__dot${i === 0 ? ' is-active' : ''}`}
              data-idx={i}
              role="tab"
              aria-label={`Image ${i + 1}`}
              aria-selected={i === 0 ? 'true' : 'false'}
            ></button>
          ))}
        </div>
      ) : (
        <div class="slideshow__progress" aria-hidden="true">
          <div class="slideshow__progress-fill" id="ss-progress"
               style={`width: ${(1/count*100).toFixed(2)}%`}></div>
        </div>
      )}

      <!-- Keyboard hint -->
      <span class="slideshow__hint" aria-hidden="true">← → keys</span>
    </div>

  </div>
) : (
  <div class="gallery-empty">
    <p>Nothing here yet.</p>
    <small>
      Drop image files into <code>/public/art/</code> and rebuild —
      they'll appear here automatically.<br />
      Supported: PNG · JPG · GIF · WEBP
    </small>
  </div>
)}

<script define:vars={{ itemsJson, count, useDots }}>
(function () {
  const items   = JSON.parse(itemsJson);
  if (!items.length) return;

  const img      = document.getElementById('ss-img');
  const loader   = document.getElementById('ss-loader');
  const filename = document.getElementById('ss-filename');
  const ext      = document.getElementById('ss-ext');
  const counter  = document.getElementById('ss-counter');
  const prev     = document.getElementById('ss-prev');
  const next     = document.getElementById('ss-next');
  const stage    = document.getElementById('ss-stage');

  // Dot or progress bar references
  const dots     = useDots
    ? Array.from(document.querySelectorAll('.slideshow__dot'))
    : null;
  const progFill = !useDots
    ? document.getElementById('ss-progress')
    : null;

  let current = 0;
  let loading = false;

  function goTo(idx) {
    if (loading) return;
    if (idx === current && img.src) return;  // already showing
    if (idx < 0) idx = count - 1;
    if (idx >= count) idx = 0;

    const item = items[idx];
    loading = true;

    // Fade out current image
    img.classList.add('is-loading');
    loader.classList.add('is-visible');

    // GIF performance: clear src FIRST so the old GIF stops decoding
    // Use a tiny transparent pixel as placeholder to release memory
    img.src = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7';

    // Small tick to let browser release GIF resources before loading next
    setTimeout(() => {
      const newImg = new Image();
      newImg.decoding = 'async';

      newImg.onload = () => {
        img.src = newImg.src;
        img.alt = item.filename.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ');
        img.classList.remove('is-loading');
        loader.classList.remove('is-visible');

        // Update metadata
        filename.textContent = item.filename;
        ext.textContent = item.ext.toUpperCase() + (item.isGif ? ' · animated' : '');
        counter.textContent = `${idx + 1} / ${count}`;

        // Update dots
        if (dots) {
          dots[current]?.classList.remove('is-active');
          dots[current]?.setAttribute('aria-selected', 'false');
          dots[idx]?.classList.add('is-active');
          dots[idx]?.setAttribute('aria-selected', 'true');
        }

        // Update progress bar
        if (progFill) {
          progFill.style.width = `${((idx + 1) / count * 100).toFixed(2)}%`;
        }

        current = idx;
        loading = false;
      };

      newImg.onerror = () => {
        // If image fails, skip it
        img.classList.remove('is-loading');
        loader.classList.remove('is-visible');
        loading = false;
      };

      newImg.src = item.src;
    }, 40); // 40ms lets browser GC the old GIF
  }

  // Arrow buttons
  prev?.addEventListener('click', () => goTo(current - 1));
  next?.addEventListener('click', () => goTo(current + 1));

  // Dot buttons
  dots?.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });

  // Keyboard navigation (arrow keys, while focus is anywhere on the page)
  document.addEventListener('keydown', e => {
    // Don't capture if user is typing in an input
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowLeft')  goTo(current - 1);
    if (e.key === 'ArrowRight') goTo(current + 1);
  });

  // Mobile: tap stage to toggle metadata
  stage?.addEventListener('click', e => {
    if (window.innerWidth < 640) {
      // Don't toggle if tapping arrows
      if ((e.target as Element).closest('.slideshow__arrow')) return;
      stage.classList.toggle('meta-open');
    }
  });

  // Touch swipe support
  let touchStartX = 0;
  stage?.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  stage?.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) {
      dx < 0 ? goTo(current + 1) : goTo(current - 1);
    }
  }, { passive: true });
})();
</script>
