---
/* src/pages/interactive.astro
  
   ADDING A NEW GAME
  ───────────────
   1. Add an entry to the GAMES array in the <script> block at the bottom.
    Each game is: { id: 'my-game', title: 'My Game', init: fn, destroy: fn }
      init(canvas) is called when the game becomes active.
      destroy() is called when switching away — stop your RAF loop there.
   2. Add a <div class="game-slot" data-game="my-game"> ... </div> block
      in the HTML below, containing whatever DOM the game needs.
   3. The switcher handles showing/hiding slots and calling init/destroy.
*/

import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/interactive.css';
---
<BaseLayout
  title="Interactive — Ethan Hammel"
  description="Interactive experiments and games."
  page="interactive"
>

<div class="interactive-page">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb__sep">›</span>
    <span class="breadcrumb__current">Interactive</span>
  </nav>

  <h1>Interactive</h1>

  <!-- ── Multi-game switcher ─────────────────────────────────── -->
  <div class="game-switcher" id="game-switcher">

    <button class="game-nav game-nav--prev" id="game-prev" aria-label="Previous game">‹</button>
    <button class="game-nav game-nav--next" id="game-next" aria-label="Next game">›</button>

    <!-- Game title, description, index — updated by JS on switch -->
    <div class="game-title-strip">
      <span class="game-index" id="game-index">1 / 1</span>
      <h2 id="game-title">Drift Racer</h2>
    </div>
    <p class="game-description" id="game-description">
      An open-world drift racer. Pull the handbrake to kick the rear out, boost through straights, and lay down paint trails with tyre tracks.
    </p>

    <!-- ══════════════════════════════════════════════════════════
         GAME SLOT 1 — Drift Racer
    ══════════════════════════════════════════════════════════ -->
    <div class="game-slot is-active" data-game="drift">
      <div class="game-wrapper">
        <div class="game-header">
          <span class="game-label">
            WASD / arrows = steer &nbsp;·&nbsp; Space = handbrake &nbsp;·&nbsp; Shift = boost &nbsp;·&nbsp; P = paint &nbsp;·&nbsp; C = clear
          </span>
        </div>
        <canvas id="race-canvas" tabindex="0"></canvas>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════
         TEMPLATE — copy this entire block to add a new game.
         Replace every instance of "my-new-game" with your game id.

    <div class="game-slot" data-game="my-new-game">
      <div class="game-wrapper">
        <div class="game-header">
          <span class="game-label">Controls description here</span>
        </div>
        <canvas id="my-canvas" tabindex="0"></canvas>
      </div>
    </div>
    ══════════════════════════════════════════════════════════ -->

    <!-- Dot indicators -->
    <div class="game-dots" id="game-dots"></div>

  </div>

</div>

<script>
(function () {

// ══════════════════════════════════════════════════════════════
// MULTI-GAME SWITCHER FRAMEWORK
// ══════════════════════════════════════════════════════════════

const GAMES = [
  {
    id:          'drift',
    title:       'Drift Racer',
    description: 'An open-world drift racer. Pull the handbrake to kick the rear out, boost through straights, and lay down paint trails with tyre tracks.',
    init:        (el) => initDrift(el),
    destroy:     () => destroyDrift(),
  },
  // ── Add more games below ──
  // {
  //   id:          'my-game',
  //   title:       'My Game Title',
  //   description: 'One or two sentences describing the game and its controls.',
  //   init:        (el) => { /* start your game */ },
  //   destroy:     () => { /* stop RAF, clean up */ },
  // },
];

let currentGame = 0;
const slots  = document.querySelectorAll('.game-slot');
const dots   = document.getElementById('game-dots');
const title  = document.getElementById('game-title');
const desc   = document.getElementById('game-description');
const index  = document.getElementById('game-index');
const btnPrev= document.getElementById('game-prev');
const btnNext= document.getElementById('game-next');

GAMES.forEach((g, i) => {
  const d = document.createElement('button');
  d.className = 'game-dot' + (i===0?' is-active':'');
  d.setAttribute('aria-label', g.title);
  d.addEventListener('click', () => switchTo(i));
  dots.appendChild(d);
});

function switchTo(idx) {
  if (idx === currentGame) return;
  GAMES[currentGame]?.destroy?.();
  slots.forEach(s => s.classList.remove('is-active'));
  document.querySelectorAll('.game-dot').forEach(d => d.classList.remove('is-active'));

  currentGame = idx;
  const g = GAMES[idx];

  const slot = document.querySelector('[data-game="' + g.id + '"]');
  slot?.classList.add('is-active');
  document.querySelectorAll('.game-dot')[idx]?.classList.add('is-active');
  title.textContent = g.title;
  if (desc) desc.textContent = g.description || '';
  index.textContent = (idx+1) + ' / ' + GAMES.length;
  btnPrev.disabled = idx === 0;
  btnNext.disabled = idx === GAMES.length - 1;

  // Defer init by one rAF so the slot is visible and has real layout dimensions
  requestAnimationFrame(() => g.init?.(slot));
}

btnPrev.addEventListener('click', () => switchTo(currentGame - 1));
btnNext.addEventListener('click', () => switchTo(currentGame + 1));
btnPrev.disabled = true;
btnNext.disabled = GAMES.length <= 1;
index.textContent = '1 / ' + GAMES.length;

// Init first game deferred — critical fix: canvas.parentElement.clientWidth
// is 0 when the script first runs; one rAF tick lets the browser lay out
// the DOM so resize() reads the real pixel width.
requestAnimationFrame(() => {
  GAMES[0]?.init?.(document.querySelector('[data-game="' + GAMES[0].id + '"]'));
});


// ══════════════════════════════════════════════════════════════
// DRIFT RACER
// ══════════════════════════════════════════════════════════════
let driftRAF = null;
let driftKeys = {};
let driftPaintMode = false;
let driftPaintIdx  = 0;
let rebuildTrack   = () => {};

function driftKeyDown(e) {
  driftKeys[e.code] = true;
  if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','Space'].includes(e.code)) {
    e.preventDefault();
  }
  if (e.code === 'KeyP') {
    driftPaintMode = !driftPaintMode;
    if (driftPaintMode) driftPaintIdx = (driftPaintIdx + 1) % PAINT_COLS.length;
  }
  if (e.code === 'KeyC') rebuildTrack();
}
function driftKeyUp(e) { driftKeys[e.code] = false; }

function destroyDrift() {
  if (driftRAF) { cancelAnimationFrame(driftRAF); driftRAF = null; }
  window.removeEventListener('keydown', driftKeyDown);
  window.removeEventListener('keyup',   driftKeyUp);
  driftKeys = {};
}

const PAINT_COLS = [
  'rgba(74,124,63,',
  'rgba(192,57,43,',
  'rgba(52,120,190,',
  'rgba(240,165,0,',
  'rgba(155,80,190,',
  'rgba(240,240,230,',
];

function initDrift(container) {
  window.addEventListener('keydown', driftKeyDown);
  window.addEventListener('keyup',   driftKeyUp);

  const canvas = document.getElementById('race-canvas');
  const ctx    = canvas.getContext('2d');

  canvas.addEventListener('click',   () => canvas.focus(), { passive: true });
  canvas.addEventListener('keydown', e => {
    if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','Space'].includes(e.code)) e.preventDefault();
  });

  // ── resize ────────────────────────────────────────────────────
  // Called after at least one rAF tick, so clientWidth is real.
  function resize() {
    const w = canvas.parentElement ? canvas.parentElement.clientWidth : 700;
    const h = Math.max(430, Math.min(650, window.innerHeight * 0.68));
    if (canvas.width  !== w) canvas.width  = w;
    if (canvas.height !== h) canvas.height = h;
  }
  resize();
  window.addEventListener('resize', resize);

  // ── Offscreen world canvas ────────────────────────────────────
  const WORLD = 5000;
  const WO    = WORLD / 2;   // world coords: car at (0,0) → pixel (WO, WO)
  const wc    = document.createElement('canvas');
  wc.width = wc.height = WORLD;
  const wctx  = wc.getContext('2d');

  const C = {
    grass:   '#c4bc96', grassAlt: '#b9b38c',
    road:    '#6a5e4e', roadLine: '#e0d8c0',
    kerb1:   '#c0392b', kerb2:    '#f0ebe0',
    skid:    'rgba(24,16,6,',
    smoke:   'rgba(215,205,185,',
  };

  // ── Track spline (Catmull-Rom) ────────────────────────────────
  const ROAD_W = 130, KERB_W = 18, NSEG = 700;
  const CPS = [
    [0,0],[350,-550],[820,-660],[1260,-360],[1380,130],
    [1060,540],[660,640],[360,940],[60,1360],
    [-340,1450],[-760,1140],[-960,640],
    [-860,80],[-620,-300],[-160,-500],[0,0],
  ];
  const NCPS = CPS.length - 1;

  function cmr(p0,p1,p2,p3,t) {
    const t2=t*t, t3=t2*t;
    return [
      .5*((2*p1[0])+(-p0[0]+p2[0])*t+(2*p0[0]-5*p1[0]+4*p2[0]-p3[0])*t2+(-p0[0]+3*p1[0]-3*p2[0]+p3[0])*t3),
      .5*((2*p1[1])+(-p0[1]+p2[1])*t+(2*p0[1]-5*p1[1]+4*p2[1]-p3[1])*t2+(-p0[1]+3*p1[1]-3*p2[1]+p3[1])*t3),
    ];
  }

  const segs = [];
  (function buildSegs() {
    const pts = CPS.slice(0,NCPS), n = pts.length;
    for (let s=0; s<NSEG; s++) {
      const t=s/NSEG, si=Math.floor(t*n), lt=t*n-si;
      const p=cmr(pts[(si-1+n)%n],pts[si],pts[(si+1)%n],pts[(si+2)%n],lt);
      segs.push({x:p[0],y:p[1]});
    }
    for (let i=0; i<NSEG; i++) {
      const a=segs[(i-1+NSEG)%NSEG], b=segs[(i+1)%NSEG];
      const dx=b.x-a.x, dy=b.y-a.y, len=Math.hypot(dx,dy)||1;
      segs[i].dx=dx/len; segs[i].dy=dy/len;
    }
  })();

  function wp(x,y) { return [WO+x, WO+y]; }

  function drawQuad(c2,x0,y0,x1,y1,x2,y2,x3,y3,fill) {
    c2.beginPath();
    c2.moveTo(x0,y0);c2.lineTo(x1,y1);c2.lineTo(x2,y2);c2.lineTo(x3,y3);
    c2.closePath();c2.fillStyle=fill;c2.fill();
  }

  rebuildTrack = function() {
    // Grass checker
    const TW = 100;
    for (let x=0;x<WORLD;x+=TW)
      for (let y=0;y<WORLD;y+=TW) {
        wctx.fillStyle = ((x/TW+y/TW)%2===0) ? C.grass : C.grassAlt;
        wctx.fillRect(x,y,TW,TW);
      }
    // Road segments
    for (let i=0; i<NSEG; i++) {
      const a=segs[i], b=segs[(i+1)%NSEG];
      const nax=-(a.dy),nay=a.dx, nbx=-(b.dy),nby=b.dx;
      const hw=ROAD_W/2, kw=KERB_W;
      const kc = Math.floor(i/9)%2===0 ? C.kerb1 : C.kerb2;
      const [ax1,ay1]=wp(a.x+nax*(hw+kw),a.y+nay*(hw+kw));
      const [bx1,by1]=wp(b.x+nbx*(hw+kw),b.y+nby*(hw+kw));
      const [ax2,ay2]=wp(a.x+nax*hw,a.y+nay*hw);
      const [bx2,by2]=wp(b.x+nbx*hw,b.y+nby*hw);
      const [ax3,ay3]=wp(a.x-nax*hw,a.y-nay*hw);
      const [bx3,by3]=wp(b.x-nbx*hw,b.y-nby*hw);
      const [ax4,ay4]=wp(a.x-nax*(hw+kw),a.y-nay*(hw+kw));
      const [bx4,by4]=wp(b.x-nbx*(hw+kw),b.y-nby*(hw+kw));
      drawQuad(wctx,ax1,ay1,bx1,by1,bx2,by2,ax2,ay2,kc);
      drawQuad(wctx,ax4,ay4,bx4,by4,bx3,by3,ax3,ay3,kc);
      drawQuad(wctx,ax2,ay2,bx2,by2,bx3,by3,ax3,ay3,C.road);
      if (i%14<7) {
        const [mx1,my1]=wp(a.x,a.y), [mx2,my2]=wp(b.x,b.y);
        wctx.beginPath();wctx.moveTo(mx1,my1);wctx.lineTo(mx2,my2);
        wctx.strokeStyle=C.roadLine;wctx.lineWidth=2.5;wctx.stroke();
      }
    }
    // Finish line
    const fs=segs[0], fnx=-(fs.dy), fny=fs.dx, hw=ROAD_W/2;
    const SQ=8, sqW=ROAD_W/SQ, dep=48;
    for (let col=0;col<SQ;col++) for (let row=0;row<2;row++) {
      const fill=(col+row)%2===0?'#181818':'#f0ebe0';
      const ox=-hw+col*sqW, oy=row===0?-dep/2:0;
      const [x0,y0]=wp(fs.x+fnx*ox+fs.dx*oy,            fs.y+fny*ox+fs.dy*oy);
      const [x1,y1]=wp(fs.x+fnx*(ox+sqW)+fs.dx*oy,      fs.y+fny*(ox+sqW)+fs.dy*oy);
      const [x2,y2]=wp(fs.x+fnx*(ox+sqW)+fs.dx*(oy+dep/2),fs.y+fny*(ox+sqW)+fs.dy*(oy+dep/2));
      const [x3,y3]=wp(fs.x+fnx*ox+fs.dx*(oy+dep/2),    fs.y+fny*ox+fs.dy*(oy+dep/2));
      drawQuad(wctx,x0,y0,x1,y1,x2,y2,x3,y3,fill);
    }
  };
  rebuildTrack();

  // ── Car state ─────────────────────────────────────────────────
  const CAR_W=20, CAR_L=36;

  function nearSeg(x,y) {
    let best=0, bd=Infinity;
    for (let i=0;i<NSEG;i++) {
      const dx=segs[i].x-x, dy=segs[i].y-y, d=dx*dx+dy*dy;
      if (d<bd) { bd=d; best=i; }
    }
    return best;
  }

  const car = {
    x: segs[0].x, y: segs[0].y - 60,
    vx:0, vy:0,
    angle: Math.atan2(segs[1].y-segs[0].y, segs[1].x-segs[0].x),
    onTrack: true,
    boostFuel: 1,
    driftCombo: 0, driftAlpha: 0,
    lapCount:0, lapStart:null, lastLap:null, showLap:false, lapAlpha:0,
    finishSide:1,
    wheelAngle: 0,
    rearSlideVis: 0,
  };

  // Physics constants
  const ACCEL       = 0.30;
  const BRAKE_F     = 0.42;
  const TOP         = 7.2;
  const TOP_BOOST   = 12.0;
  const STEER       = 0.074;
  const STEER_SPD   = 0.38;
  const FRONT_GRIP  = 0.72;
  const REAR_GRIP   = 0.52;
  const HAND_GRIP   = 0.04;
  const GRASS_GRIP  = 0.28;
  const DRAG        = 0.980;
  const DRAG_GRASS  = 0.948;
  const BOOST_DRAIN = 0.007;
  const BOOST_REGEN = 0.003;
  const SKID_THRESH = 1.4;

  const smoke = [];

  function update() {
    const accel = driftKeys['ArrowUp']    || driftKeys['KeyW'];
    const brake = driftKeys['ArrowDown']  || driftKeys['KeyS'];
    const left  = driftKeys['ArrowLeft']  || driftKeys['KeyA'];
    const right = driftKeys['ArrowRight'] || driftKeys['KeyD'];
    const hb    = driftKeys['Space'];
    const boost = (driftKeys['ShiftLeft']||driftKeys['ShiftRight']) && car.boostFuel>0;

    if (boost) car.boostFuel = Math.max(0, car.boostFuel - BOOST_DRAIN);
    else       car.boostFuel = Math.min(1, car.boostFuel + BOOST_REGEN);

    const cosA = Math.cos(car.angle), sinA = Math.sin(car.angle);
    const fwdSpd =  car.vx*cosA  + car.vy*sinA;
    const latSpd =  car.vx*(-sinA) + car.vy*cosA;
    const spd    = Math.hypot(car.vx, car.vy);
    const topSpd = boost ? TOP_BOOST : TOP;

    if (accel && fwdSpd < topSpd) {
      const f = ACCEL * (car.onTrack?1:0.5) * (boost?1.65:1);
      car.vx += cosA*f; car.vy += sinA*f;
    }
    if (brake && spd > 0.1) {
      const bm = fwdSpd > 0 ? 1 : 0.35;
      car.vx -= cosA*BRAKE_F*bm; car.vy -= sinA*BRAKE_F*bm;
    }
    if (spd > 0.15) {
      const sa = STEER / (1 + spd*STEER_SPD) * Math.sign(fwdSpd||1);
      if (left)  car.angle -= sa;
      if (right) car.angle += sa;
      car.wheelAngle = left ? -0.45 : right ? 0.45 : 0;
    }

    const gp      = car.onTrack ? 1 : GRASS_GRIP;
    const avgGrip = (FRONT_GRIP*gp)*0.6 + ((hb?HAND_GRIP:REAR_GRIP)*gp)*0.4;
    const corrF   = latSpd * avgGrip;
    car.vx += sinA * corrF;
    car.vy -= cosA * corrF;

    if (hb && spd > 1.5) car.angle += -latSpd * 0.022;

    // Countersteer assist
    if ((latSpd > SKID_THRESH*0.8 && right) || (latSpd < -SKID_THRESH*0.8 && left)) {
      const assist = latSpd * 0.12;
      car.vx += sinA * assist;
      car.vy -= cosA * assist;
    }

    const drag = car.onTrack ? DRAG : DRAG_GRASS;
    car.vx *= drag; car.vy *= drag;

    const ns = Math.hypot(car.vx, car.vy);
    if (ns > topSpd*1.15) { car.vx=car.vx/ns*topSpd*1.15; car.vy=car.vy/ns*topSpd*1.15; }

    car.x += car.vx; car.y += car.vy;

    // On-track detection
    const si  = nearSeg(car.x, car.y);
    const seg = segs[si];
    const offT = Math.abs((car.x-seg.x)*(-(seg.dy)) + (car.y-seg.y)*seg.dx);
    car.onTrack = offT < ROAD_W*0.5 - CAR_W*0.5;

    // Skid / drift marks
    const newLat = car.vx*(-sinA) + car.vy*cosA;
    const abslat = Math.abs(newLat);
    const drifting = abslat > SKID_THRESH || hb;
    car.rearSlideVis += (newLat*0.08 - car.rearSlideVis)*0.15;

    if (drifting && ns > 0.8) {
      const sin2=Math.sin(car.angle), cos2=Math.cos(car.angle);
      const rx=car.x-cos2*CAR_L*0.36, ry=car.y-sin2*CAR_L*0.36;
      const lTx=rx+sin2*CAR_W*0.46, lTy=ry-cos2*CAR_W*0.46;
      const rTx=rx-sin2*CAR_W*0.46, rTy=ry+cos2*CAR_W*0.46;
      if (driftPaintMode) {
        const pc=PAINT_COLS[driftPaintIdx];
        const alpha=Math.min(0.92,0.35+abslat*0.07), rad=Math.min(12,2.5+abslat*1.1);
        [[lTx,lTy],[rTx,rTy]].forEach(([px,py])=>{
          wctx.beginPath();wctx.arc(WO+px,WO+py,rad,0,Math.PI*2);
          wctx.fillStyle=pc+alpha+')';wctx.fill();
        });
      } else {
        const alpha=Math.min(0.65,0.08+abslat*0.055)*(hb?1.2:0.85);
        const mw=Math.min(5,2+abslat*0.3);
        [[lTx,lTy],[rTx,rTy]].forEach(([px,py])=>{
          wctx.beginPath();wctx.arc(WO+px,WO+py,mw,0,Math.PI*2);
          wctx.fillStyle=C.skid+Math.min(0.65,alpha)+')';wctx.fill();
        });
      }
      car.driftCombo += abslat*0.05; car.driftAlpha=1;
    } else {
      car.driftCombo=Math.max(0,car.driftCombo-0.5);
      car.driftAlpha=Math.max(0,car.driftAlpha-0.04);
    }

    // Smoke
    if (drifting && ns>1.8 && Math.random()<0.65) {
      smoke.push({
        x:car.x-Math.cos(car.angle)*CAR_L*0.4+(Math.random()-.5)*6,
        y:car.y-Math.sin(car.angle)*CAR_L*0.4+(Math.random()-.5)*6,
        vx:(Math.random()-.5)*.6-car.vx*.03,
        vy:(Math.random()-.5)*.6-car.vy*.03,
        life:1, sz:4+Math.random()*7,
      });
    }
    for (let i=smoke.length-1;i>=0;i--) {
      const s=smoke[i];
      s.x+=s.vx;s.y+=s.vy;s.vx*=.96;s.vy*=.96;s.sz+=.25;s.life-=.03;
      if (s.life<=0) smoke.splice(i,1);
    }

    // Lap detection
    const fs=segs[0], fnx=-(fs.dy), fny=fs.dx;
    const dfs=Math.hypot(car.x-fs.x,car.y-fs.y);
    const side=(car.x-fs.x)*fnx+(car.y-fs.y)*fny;
    if (dfs<ROAD_W*.6) {
      if (car.finishSide>0&&side<=0&&ns>0.4) {
        car.lapCount++;
        car.lastLap = car.lapStart ? performance.now()-car.lapStart : null;
        car.lapStart = performance.now();
        car.showLap=true; car.lapAlpha=1;
      }
      car.finishSide = side>0?1:-1;
    }
    if (car.lapAlpha>0){car.lapAlpha-=.004;if(car.lapAlpha<=0){car.showLap=false;car.lapAlpha=0;}}
  }

  // ── Camera ────────────────────────────────────────────────────
  // Initialise exactly at car position → first frame is perfectly centered
  let camX = car.x;
  let camY = car.y;

  function updateCamera() {
    const spd  = Math.hypot(car.vx, car.vy);
    const lead = Math.min(spd*9, 72);
    camX += (car.x + Math.cos(car.angle)*lead - camX) * 0.065;
    camY += (car.y + Math.sin(car.angle)*lead - camY) * 0.065;
  }

  // Screen-space helpers
  function sx(x) { return (x - camX) + canvas.width  / 2; }
  function sy(y) { return (y - camY) + canvas.height / 2; }

  function drawCar() {
    const spd  = Math.hypot(car.vx,car.vy);
    const boost= (driftKeys['ShiftLeft']||driftKeys['ShiftRight'])&&car.boostFuel>0;
    const hb   = driftKeys['Space'];
    const cx=sx(car.x), cy=sy(car.y);
    const W=CAR_W, L=CAR_L;

    ctx.save();ctx.translate(cx,cy);ctx.rotate(car.angle+Math.PI/2);

    // Shadow
    ctx.save();ctx.translate(2+spd*.18,3+spd*.18);
    ctx.globalAlpha=.2;ctx.fillStyle='#100a04';
    ctx.beginPath();ctx.roundRect(-W/2,-L/2,W,L,4);ctx.fill();ctx.restore();

    // Body
    ctx.fillStyle=boost?'#d4a017':'#4a7c3f';
    ctx.beginPath();ctx.roundRect(-W/2,-L/2,W,L,4);ctx.fill();
    // Stripes
    ctx.fillStyle='#2e5228';
    ctx.fillRect(-W/2+1,-L/2+9,3,L-18);ctx.fillRect(W/2-4,-L/2+9,3,L-18);
    // Windscreen
    ctx.fillStyle='#162416';
    ctx.beginPath();ctx.roundRect(-W/2+4,-L/2+4,W-8,L*.38,2);ctx.fill();
    // Rear window
    ctx.fillStyle='rgba(22,36,22,0.6)';
    ctx.beginPath();ctx.roundRect(-W/2+5,L/2-L*.22,W-10,L*.17,1);ctx.fill();
    // Roof bar
    ctx.fillStyle='#2e5228';
    ctx.beginPath();ctx.roundRect(-W/2+3,-L/2+2,W-6,4,1);ctx.fill();
    // Wheels
    ctx.fillStyle='#1a1208';
    const ww=5,wh=11;
    [[-W/2-2,-L/2+6],[W/2-ww+2,-L/2+6]].forEach(([wx,wy])=>{
      ctx.save();ctx.translate(wx+ww/2,wy+wh/2);
      ctx.rotate(car.wheelAngle);ctx.fillRect(-ww/2,-wh/2,ww,wh);ctx.restore();
    });
    [[-W/2-2,L/2-wh-6],[W/2-ww+2,L/2-wh-6]].forEach(([wx,wy])=>{
      ctx.save();ctx.translate(wx+ww/2,wy+wh/2);
      ctx.rotate(car.rearSlideVis*.5);ctx.fillRect(-ww/2,-wh/2,ww,wh);ctx.restore();
    });
    // Boost flame
    if (boost&&spd>1.2) {
      ctx.fillStyle='#ff6600';
      ctx.beginPath();ctx.moveTo(-4,L/2);ctx.lineTo(4,L/2);
      ctx.lineTo(0,L/2+7+Math.random()*9);ctx.closePath();ctx.fill();
      ctx.fillStyle='#ffdd00';
      ctx.beginPath();ctx.moveTo(-2,L/2);ctx.lineTo(2,L/2);
      ctx.lineTo(0,L/2+3+Math.random()*4);ctx.closePath();ctx.fill();
    }
    // Handbrake tail-lights
    if (hb) {
      ctx.save();ctx.globalAlpha=.6;ctx.fillStyle='#ff2200';
      ctx.fillRect(-W/2+2,L/2-5,5,3);ctx.fillRect(W/2-7,L/2-5,5,3);ctx.restore();
    }
    ctx.restore();
  }

  function drawSmoke() {
    smoke.forEach(s=>{
      ctx.beginPath();ctx.arc(sx(s.x),sy(s.y),s.sz,0,Math.PI*2);
      ctx.fillStyle=C.smoke+s.life*.32+')';ctx.fill();
    });
  }

  function drawHUD() {
    const spd   = Math.hypot(car.vx,car.vy);
    const boost = (driftKeys['ShiftLeft']||driftKeys['ShiftRight'])&&car.boostFuel>0;
    const hb    = driftKeys['Space'];
    const bw=115,bh=9,bx=16,by=canvas.height-30;

    ctx.fillStyle='rgba(30,22,8,0.45)';
    ctx.beginPath();ctx.roundRect(bx,by,bw,bh,3);ctx.fill();
    const grad=ctx.createLinearGradient(bx,0,bx+bw,0);
    grad.addColorStop(0,'#4a7c3f');grad.addColorStop(1,'#d4a017');
    ctx.fillStyle=boost?grad:'#4a7c3f';
    ctx.beginPath();ctx.roundRect(bx,by,bw*car.boostFuel,bh,3);ctx.fill();
    ctx.font='9px "DM Mono",monospace';
    ctx.textAlign='left';ctx.textBaseline='bottom';
    ctx.fillStyle='rgba(240,232,210,0.7)';ctx.fillText('BOOST',bx,by-3);

    if (hb) {
      ctx.fillStyle='rgba(200,50,30,0.9)';ctx.fillText('■ HAND BRAKE',bx,by-16);
    }
    if (car.driftAlpha>0) {
      const sc=Math.min(car.driftCombo/20,1);
      ctx.save();ctx.globalAlpha=car.driftAlpha;
      ctx.font='bold '+(12+sc*8|0)+'px "DM Mono",monospace';
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.shadowColor='rgba(240,165,0,0.6)';ctx.shadowBlur=sc*14;
      ctx.fillStyle='rgba(240,'+(140+sc*100|0)+',0,1)';
      ctx.fillText(car.driftCombo>15?'STYLE!':car.driftCombo>8?'DRIFT!':'drift',
                   canvas.width/2, canvas.height-18);
      ctx.shadowBlur=0;ctx.restore();
    }
    if (driftPaintMode) {
      ctx.beginPath();ctx.arc(canvas.width-30,20,7,0,Math.PI*2);
      ctx.fillStyle=PAINT_COLS[driftPaintIdx]+'0.9)';ctx.fill();
      ctx.fillStyle='rgba(240,232,210,0.75)';
      ctx.font='9px "DM Mono",monospace';ctx.textAlign='right';ctx.textBaseline='top';
      ctx.fillText('PAINT',canvas.width-42,14);
    }
    if (car.showLap&&car.lapAlpha>0) {
      const dfs=Math.hypot(car.x-segs[0].x,car.y-segs[0].y);
      if (dfs<520) {
        const txt=car.lastLap
          ?'Lap '+car.lapCount+'  ·  '+(car.lastLap/1000).toFixed(2)+'s'
          :'Lap '+car.lapCount+'  ·  GO';
        ctx.save();ctx.globalAlpha=Math.min(1,car.lapAlpha);
        ctx.font='bold 14px "DM Mono",monospace';
        ctx.textAlign='center';ctx.textBaseline='middle';
        const tw=ctx.measureText(txt).width+36,th=32,px=canvas.width/2,py=52;
        ctx.fillStyle='rgba(20,14,4,0.78)';
        ctx.beginPath();ctx.roundRect(px-tw/2,py-th/2,tw,th,6);ctx.fill();
        ctx.fillStyle='#f0ebe0';ctx.fillText(txt,px,py);ctx.restore();
      }
    }
  }

  // ── Main loop ─────────────────────────────────────────────────
  function frame() {
    // Safety guard: if canvas somehow still has no size, retry next tick
    if (canvas.width < 10 || canvas.height < 10) {
      resize();
      driftRAF = requestAnimationFrame(frame);
      return;
    }

    update();
    updateCamera();

    // Clamp drawImage source rect strictly within the world canvas bounds
    const srcX = Math.max(0, Math.min(WORLD - canvas.width,  Math.round(WO + camX - canvas.width  / 2)));
    const srcY = Math.max(0, Math.min(WORLD - canvas.height, Math.round(WO + camY - canvas.height / 2)));
    ctx.drawImage(wc, srcX, srcY, canvas.width, canvas.height,
                      0,    0,    canvas.width, canvas.height);

    drawSmoke();
    drawCar();
    drawHUD();

    driftRAF = requestAnimationFrame(frame);
  }

  canvas.focus();
  driftRAF = requestAnimationFrame(frame);
}

})();
</script>

</BaseLayout>
