---
// src/pages/interactive.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/interactive.css';
---
<BaseLayout
  title="Interactive — Ethan Hammel"
  description="Interactive projects and experiments."
  page="interactive"
>

<div class="interactive-page">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb__sep">›</span>
    <span class="breadcrumb__current">Interactive</span>
  </nav>

  <h1>Interactive Projects</h1>

  <!-- ── Racing Game ─────────────────────────────────────────── -->
  <div class="game-wrapper">
    <div class="game-header">
      <span class="game-label">Open World Racer</span>
      <span class="game-controls">WASD / Arrow keys &nbsp;·&nbsp; Shift or Space = boost</span>
    </div>
    <canvas id="race-canvas"></canvas>
  </div>

</div>

<script>
(function () {

// ── Canvas setup ──────────────────────────────────────────────
const canvas = document.getElementById('race-canvas');
const ctx    = canvas.getContext('2d');

function resize() {
  const wrapper = canvas.parentElement;
  canvas.width  = wrapper.clientWidth;
  canvas.height = Math.max(420, Math.min(620, window.innerHeight * 0.65));
}
resize();
window.addEventListener('resize', resize);

// ── Colours (match site palette) ─────────────────────────────
const C = {
  grass:      '#c8c09a',
  grassDark:  '#bdb490',
  road:       '#6b6050',
  roadLine:   '#e8dfc8',
  roadEdge:   '#4a3e2e',
  kerb1:      '#c0392b',
  kerb2:      '#f5f0e8',
  car:        '#4a7c3f',
  carDark:    '#2e5228',
  carWindow:  '#1a2e1a',
  carWheel:   '#1a1208',
  boost:      '#f0a500',
  lapLine:    '#e8dfc8',
  lapText:    '#f5f0e8',
  shadow:     'rgba(58,46,30,0.18)',
  sky:        '#f5f0e8',
};

// ── Track definition ──────────────────────────────────────────
// The track is a closed loop of cubic bezier control points in
// world-space. We sample it into many small segments for drawing
// and collision. The world is effectively infinite — the car drives
// around the loop forever.

const ROAD_W    = 110;   // road width in world px
const KERB_W    = 14;
const TRACK_SEG = 600;   // number of segments to sample

// Control points for a looping figure-8 style track
// (x, y) in world units — large numbers so the world feels open
const CP = [
  [0,    0],
  [400,  -600],
  [900,  -700],
  [1300, -400],
  [1400,  100],
  [1100,  500],
  [700,   600],
  [400,   900],
  [100,  1300],
  [-300, 1400],
  [-700, 1100],
  [-900,  600],
  [-800,  100],
  [-600, -300],
  [-200, -500],
  [0,    0],
];
const N = CP.length - 1; // last point == first (closed)

function catmull(p0, p1, p2, p3, t) {
  // Centripetal Catmull-Rom
  const t2 = t*t, t3 = t2*t;
  return [
    0.5*((2*p1[0]) + (-p0[0]+p2[0])*t + (2*p0[0]-5*p1[0]+4*p2[0]-p3[0])*t2 + (-p0[0]+3*p1[0]-3*p2[0]+p3[0])*t3),
    0.5*((2*p1[1]) + (-p0[1]+p2[1])*t + (2*p0[1]-5*p1[1]+4*p2[1]-p3[1])*t2 + (-p0[1]+3*p1[1]-3*p2[1]+p3[1])*t3),
  ];
}

// Sample track into segments
const track = []; // { x, y, dx, dy, len } — centre points + tangents
(function buildTrack() {
  const pts = CP.slice(0, N); // without the duplicate last point
  const n   = pts.length;
  for (let s = 0; s < TRACK_SEG; s++) {
    const t   = s / TRACK_SEG;
    const seg = Math.floor(t * n);
    const lt  = (t * n) - seg;
    const p0  = pts[(seg - 1 + n) % n];
    const p1  = pts[seg];
    const p2  = pts[(seg + 1) % n];
    const p3  = pts[(seg + 2) % n];
    const pos = catmull(p0, p1, p2, p3, lt);
    track.push({ x: pos[0], y: pos[1] });
  }
  // Compute tangents
  for (let i = 0; i < TRACK_SEG; i++) {
    const a = track[(i - 1 + TRACK_SEG) % TRACK_SEG];
    const b = track[(i + 1) % TRACK_SEG];
    const dx = b.x - a.x, dy = b.y - a.y;
    const len = Math.sqrt(dx*dx + dy*dy) || 1;
    track[i].dx = dx/len;
    track[i].dy = dy/len;
    track[i].len = len;
  }
})();

// Finish line is at track[0]
const FINISH_SEG = 0;

// ── Player car ────────────────────────────────────────────────
const car = {
  x: track[0].x,
  y: track[0].y - 40,
  vx: 0,
  vy: 0,
  angle: Math.atan2(track[1].y - track[0].y, track[1].x - track[0].x),
  speed: 0,
  boost:      false,
  boostFuel:  1.0,   // 0..1
  onTrack:    true,
  // Lap tracking
  lapStartTime: null,
  lastLapTime:  null,
  lapCount:     0,
  // Which side of finish line car was on last frame
  finishSide: 1,
  // For finish line display
  showLapTimer: false,
  lapTimerAlpha: 0,
};

// ── Input ─────────────────────────────────────────────────────
const keys = {};
window.addEventListener('keydown', e => {
  keys[e.code] = true;
  // Prevent page scroll on arrow keys / space when canvas is focused
  if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','Space'].includes(e.code)) {
    e.preventDefault();
  }
});
window.addEventListener('keyup', e => { keys[e.code] = false; });

// Touch / mobile: virtual joystick state
let touchLeft  = false, touchRight = false;
let touchAccel = false, touchBrake = false, touchBoost = false;

// ── Find nearest track segment ────────────────────────────────
function nearestSeg(x, y) {
  let best = 0, bestD = Infinity;
  for (let i = 0; i < TRACK_SEG; i++) {
    const dx = track[i].x - x, dy = track[i].y - y;
    const d  = dx*dx + dy*dy;
    if (d < bestD) { bestD = d; best = i; }
  }
  return best;
}

// ── Physics update ────────────────────────────────────────────
const MAX_SPEED      = 5.5;
const MAX_SPEED_BOOST= 9.5;
const ACCEL          = 0.18;
const BRAKE_FORCE    = 0.28;
const FRICTION       = 0.94;
const GRASS_FRICTION = 0.80;
const STEER          = 0.052;
const BOOST_DRAIN    = 0.008;
const BOOST_REGEN    = 0.003;
const CAR_W = 18, CAR_L = 32;

function update() {
  const boosting = (keys['ShiftLeft'] || keys['ShiftRight'] || keys['Space'] || touchBoost) && car.boostFuel > 0;
  car.boost = boosting;
  if (boosting) car.boostFuel = Math.max(0, car.boostFuel - BOOST_DRAIN);
  else          car.boostFuel = Math.min(1, car.boostFuel + BOOST_REGEN);

  const accel  = keys['ArrowUp']    || keys['KeyW'] || touchAccel;
  const brake  = keys['ArrowDown']  || keys['KeyS'] || touchBrake;
  const left   = keys['ArrowLeft']  || keys['KeyA'] || touchLeft;
  const right  = keys['ArrowRight'] || keys['KeyD'] || touchRight;

  const topSpeed = boosting ? MAX_SPEED_BOOST : MAX_SPEED;

  if (accel) car.speed = Math.min(topSpeed, car.speed + ACCEL * (car.onTrack ? 1 : 0.6));
  if (brake) car.speed = Math.max(-MAX_SPEED*0.4, car.speed - BRAKE_FORCE);

  const friction = car.onTrack ? FRICTION : GRASS_FRICTION;
  car.speed *= friction;
  if (Math.abs(car.speed) < 0.01) car.speed = 0;

  if (Math.abs(car.speed) > 0.1) {
    const steerAmt = STEER * (1 - Math.abs(car.speed) / (topSpeed * 2));
    if (left)  car.angle -= steerAmt * Math.sign(car.speed);
    if (right) car.angle += steerAmt * Math.sign(car.speed);
  }

  car.x += Math.cos(car.angle) * car.speed;
  car.y += Math.sin(car.angle) * car.speed;

  // Check if on track
  const seg = nearestSeg(car.x, car.y);
  const t   = track[seg];
  const nx  = -(t.dy), ny = t.dx; // normal to track
  const offT = (car.x - t.x) * nx + (car.y - t.y) * ny;
  car.onTrack = Math.abs(offT) < ROAD_W * 0.5 - CAR_W;

  // ── Finish line crossing detection ────────────────────────────
  // Finish line is at track[FINISH_SEG]. Check which side of the
  // finish-line normal the car is on. When it flips from + to -
  // while near the line, a lap is registered.
  const fs  = track[FINISH_SEG];
  const fnx = -(fs.dy), fny = fs.dx;
  const distToFinish = Math.sqrt((car.x-fs.x)**2 + (car.y-fs.y)**2);
  const side = (car.x - fs.x) * fnx + (car.y - fs.y) * fny;

  if (distToFinish < ROAD_W * 0.55) {
    // Car is near finish line
    if (car.finishSide > 0 && side <= 0 && car.speed > 0.5) {
      // Crossed from front to back going forward — lap complete / started
      car.lapCount++;
      car.lastLapTime = car.lapStartTime ? (performance.now() - car.lapStartTime) : null;
      car.lapStartTime = performance.now();
      car.showLapTimer = true;
      car.lapTimerAlpha = 1.0;
    }
    car.finishSide = side > 0 ? 1 : -1;
  }

  // Fade lap timer display
  if (car.showLapTimer && car.lapTimerAlpha > 0) {
    car.lapTimerAlpha -= 0.004;
    if (car.lapTimerAlpha <= 0) { car.showLapTimer = false; car.lapTimerAlpha = 0; }
  }
}

// ── Camera ────────────────────────────────────────────────────
let camX = car.x, camY = car.y;
function updateCamera() {
  // Smooth follow
  camX += (car.x - camX) * 0.08;
  camY += (car.y - camY) * 0.08;
}

// ── Draw helpers ──────────────────────────────────────────────
function wx(x) { return (x - camX) + canvas.width  / 2; }
function wy(y) { return (y - camY) + canvas.height / 2; }

// Draw a road segment quad between two track points
function drawSegment(i) {
  const a  = track[i];
  const b  = track[(i+1) % TRACK_SEG];
  const nax = -(a.dy), nay = a.dx;
  const nbx = -(b.dy), nby = b.dx;

  const hw = ROAD_W / 2;
  const kw = KERB_W;

  // Grass is handled by the background fill
  // Kerb strips (alternating red/white every few segments)
  const kerbCol = Math.floor(i / 8) % 2 === 0 ? C.kerb1 : C.kerb2;

  // Outer kerb
  ctx.beginPath();
  ctx.moveTo(wx(a.x + nax*(hw+kw)), wy(a.y + nay*(hw+kw)));
  ctx.lineTo(wx(b.x + nbx*(hw+kw)), wy(b.y + nby*(hw+kw)));
  ctx.lineTo(wx(b.x + nbx*hw),       wy(b.y + nby*hw));
  ctx.lineTo(wx(a.x + nax*hw),       wy(a.y + nay*hw));
  ctx.closePath();
  ctx.fillStyle = kerbCol;
  ctx.fill();

  // Inner kerb
  ctx.beginPath();
  ctx.moveTo(wx(a.x - nax*(hw+kw)), wy(a.y - nay*(hw+kw)));
  ctx.lineTo(wx(b.x - nbx*(hw+kw)), wy(b.y - nby*(hw+kw)));
  ctx.lineTo(wx(b.x - nbx*hw),       wy(b.y - nby*hw));
  ctx.lineTo(wx(a.x - nax*hw),       wy(a.y - nay*hw));
  ctx.closePath();
  ctx.fillStyle = kerbCol;
  ctx.fill();

  // Road surface
  ctx.beginPath();
  ctx.moveTo(wx(a.x + nax*hw), wy(a.y + nay*hw));
  ctx.lineTo(wx(b.x + nbx*hw), wy(b.y + nby*hw));
  ctx.lineTo(wx(b.x - nbx*hw), wy(b.y - nby*hw));
  ctx.lineTo(wx(a.x - nax*hw), wy(a.y - nay*hw));
  ctx.closePath();
  ctx.fillStyle = C.road;
  ctx.fill();

  // Centre dashes every 12 segs
  if (i % 12 < 6) {
    ctx.beginPath();
    ctx.moveTo(wx(a.x), wy(a.y));
    ctx.lineTo(wx(b.x), wy(b.y));
    ctx.strokeStyle = C.roadLine;
    ctx.lineWidth = 2;
    ctx.setLineDash([]);
    ctx.stroke();
  }
}

// Draw finish line
function drawFinishLine() {
  const seg = track[FINISH_SEG];
  const nx  = -(seg.dy), ny = seg.dx;
  const hw  = ROAD_W / 2;
  const fw  = 40; // depth of finish line in direction of travel
  const td  = seg; // tangent

  const squares = 8;
  const sqW = (ROAD_W) / squares;

  for (let col = 0; col < squares; col++) {
    for (let row = 0; row < 2; row++) {
      const fill = (col + row) % 2 === 0 ? '#1a1a1a' : '#f5f0e8';
      const ox = -hw + col * sqW;
      const oy = row === 0 ? -fw/2 : 0;
      const x0 = seg.x + nx*ox  + td.dx*oy;
      const y0 = seg.y + ny*ox  + td.dy*oy;
      const x1 = seg.x + nx*(ox+sqW) + td.dx*oy;
      const y1 = seg.y + ny*(ox+sqW) + td.dy*oy;
      const x2 = seg.x + nx*(ox+sqW) + td.dx*(oy+fw/2);
      const y2 = seg.y + ny*(ox+sqW) + td.dy*(oy+fw/2);
      const x3 = seg.x + nx*ox  + td.dx*(oy+fw/2);
      const y3 = seg.y + ny*ox  + td.dy*(oy+fw/2);
      ctx.beginPath();
      ctx.moveTo(wx(x0),wy(y0)); ctx.lineTo(wx(x1),wy(y1));
      ctx.lineTo(wx(x2),wy(y2)); ctx.lineTo(wx(x3),wy(y3));
      ctx.closePath();
      ctx.fillStyle = fill;
      ctx.fill();
    }
  }
}

// Draw car
function drawCar() {
  const cx = wx(car.x), cy = wy(car.y);
  ctx.save();
  ctx.translate(cx, cy);
  ctx.rotate(car.angle + Math.PI/2); // nose points up in local space

  const W = CAR_W, L = CAR_L;

  // Shadow
  ctx.save();
  ctx.translate(3, 4);
  ctx.fillStyle = C.shadow;
  ctx.beginPath();
  ctx.roundRect(-W/2, -L/2, W, L, 4);
  ctx.fill();
  ctx.restore();

  // Body
  ctx.fillStyle = car.boost ? C.boost : C.car;
  ctx.beginPath();
  ctx.roundRect(-W/2, -L/2, W, L, 4);
  ctx.fill();

  // Cockpit/window
  ctx.fillStyle = C.carWindow;
  ctx.beginPath();
  ctx.roundRect(-W/2+4, -L/2+5, W-8, L*0.45, 2);
  ctx.fill();

  // Dark roof accent
  ctx.fillStyle = C.carDark;
  ctx.beginPath();
  ctx.roundRect(-W/2+2, -L/2+2, W-4, 5, 1);
  ctx.fill();

  // Wheels (4 corners)
  ctx.fillStyle = C.carWheel;
  const ww = 5, wh = 9;
  [[-W/2-2, -L/2+4], [W/2-ww+2, -L/2+4],
   [-W/2-2,  L/2-wh-4], [W/2-ww+2,  L/2-wh-4]].forEach(([wx2,wy2]) => {
    ctx.fillRect(wx2, wy2, ww, wh);
  });

  // Boost flame
  if (car.boost && car.speed > 1) {
    ctx.fillStyle = '#ff6600';
    ctx.beginPath();
    ctx.moveTo(-4, L/2);
    ctx.lineTo( 4, L/2);
    ctx.lineTo( 0, L/2 + 8 + Math.random()*6);
    ctx.closePath();
    ctx.fill();
  }

  ctx.restore();
}

// Draw boost bar (bottom left of canvas, always visible)
function drawBoostBar() {
  const bw = 100, bh = 8;
  const bx = 16, by = canvas.height - 28;
  ctx.fillStyle = 'rgba(58,46,30,0.35)';
  ctx.beginPath(); ctx.roundRect(bx, by, bw, bh, 3); ctx.fill();
  ctx.fillStyle = car.boost ? C.boost : C.car;
  ctx.beginPath(); ctx.roundRect(bx, by, bw * car.boostFuel, bh, 3); ctx.fill();
  ctx.font = '9px "DM Mono", monospace';
  ctx.fillStyle = 'rgba(58,46,30,0.6)';
  ctx.fillText('BOOST', bx, by - 4);
}

// Draw grass tile pattern (simple checkerboard behind everything)
function drawGrass() {
  const tw = 80;
  const offX = ((camX % tw) + tw) % tw;
  const offY = ((camY % tw) + tw) % tw;
  for (let gx = -tw; gx < canvas.width + tw; gx += tw) {
    for (let gy = -tw; gy < canvas.height + tw; gy += tw) {
      const tx = Math.floor((gx + offX - camX + canvas.width/2) / tw);
      const ty = Math.floor((gy + offY - camY + canvas.height/2) / tw);
      ctx.fillStyle = (tx + ty) % 2 === 0 ? C.grass : C.grassDark;
      ctx.fillRect(gx - offX, gy - offY, tw, tw);
    }
  }
}

// ── Lap time display ─────────────────────────────────────────
// Only drawn when car is above (or crossing) the finish line.
// Visibility determined purely by proximity + side of finish line.
function drawLapInfo() {
  if (!car.showLapTimer || car.lapTimerAlpha <= 0) return;

  // Only show when near the finish line
  const fs = track[FINISH_SEG];
  const distToFinish = Math.sqrt((car.x-fs.x)**2 + (car.y-fs.y)**2);
  if (distToFinish > 400) return;

  const alpha = Math.min(1, car.lapTimerAlpha);
  const cx = canvas.width / 2;
  const cy = 56;

  ctx.save();
  ctx.globalAlpha = alpha;

  // Background pill
  const text = car.lastLapTime
    ? `Lap ${car.lapCount}  ·  ${(car.lastLapTime/1000).toFixed(2)}s`
    : `Lap ${car.lapCount}  ·  GO`;
  ctx.font = 'bold 15px "DM Mono", monospace';
  const tw = ctx.measureText(text).width;
  const pw = tw + 32, ph = 32;
  ctx.fillStyle = 'rgba(26,18,8,0.72)';
  ctx.beginPath();
  ctx.roundRect(cx - pw/2, cy - ph/2, pw, ph, 6);
  ctx.fill();

  ctx.fillStyle = C.lapText;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(text, cx, cy);

  ctx.restore();
}

// ── Main loop ─────────────────────────────────────────────────
function frame() {
  update();
  updateCamera();

  // Background
  drawGrass();

  // Draw all visible track segments
  for (let i = 0; i < TRACK_SEG; i++) {
    const sx = wx(track[i].x), sy = wy(track[i].y);
    // Rough cull — skip if far off screen
    if (sx < -200 || sx > canvas.width+200 || sy < -200 || sy > canvas.height+200) continue;
    drawSegment(i);
  }

  drawFinishLine();
  drawCar();
  drawBoostBar();
  drawLapInfo();

  requestAnimationFrame(frame);
}

requestAnimationFrame(frame);

// ── Mobile touch controls ────────────────────────────────────
// Only add if touch device
if ('ontouchstart' in window) {
  const overlay = document.querySelector('.game-touch');
  if (overlay) {
    // Simple virtual dpad
    const makeBtn = (label, x, y, w, h, onDown, onUp) => {
      const div = document.createElement('div');
      div.className = 'touch-btn';
      div.textContent = label;
      div.style.cssText = `left:${x}px;bottom:${y}px;width:${w}px;height:${h}px`;
      div.addEventListener('touchstart', e => { e.preventDefault(); onDown(); }, { passive: false });
      div.addEventListener('touchend',   e => { e.preventDefault(); onUp();   }, { passive: false });
      overlay.appendChild(div);
    };
    makeBtn('▲', 60, 90, 50, 50,  () => touchAccel=true,  () => touchAccel=false);
    makeBtn('▼', 60, 30, 50, 50,  () => touchBrake=true,  () => touchBrake=false);
    makeBtn('◀', 5,  60, 50, 50,  () => touchLeft=true,   () => touchLeft=false);
    makeBtn('▶', 115,60, 50, 50,  () => touchRight=true,  () => touchRight=false);
    makeBtn('⚡',canvas.width-70,30,60,50, () => touchBoost=true, () => touchBoost=false);
  }
}

})();
</script>

</BaseLayout>
