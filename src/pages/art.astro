---
// src/pages/art.astro
// Auto-detects all images in /public/art/ at build time.
// Drop a file in → rebuild → it appears. No code changes needed.
// Supported: .png .gif .jpg .jpeg .webp

import BaseLayout from '../layouts/BaseLayout.astro';
import ArtGallery  from '../components/ArtGallery.astro';
import '../styles/art.css';

// Glob all image files from /public/art/
const imageFiles = import.meta.glob(
  '/public/art/*.{png,gif,jpg,jpeg,webp}',
  { eager: true }
);

// Build typed gallery items
const galleryItems = Object.entries(imageFiles)
  .map(([path, _mod]) => {
    const filename = path.split('/').pop() ?? path;
    const ext      = filename.split('.').pop()?.toLowerCase() ?? '';
    return {
      src:      path.replace('/public', ''),
      filename,
      ext,
      isGif: ext === 'gif',
      path,
    };
  })
  .sort((a, b) => a.filename.localeCompare(b.filename));
---

<BaseLayout
  title="Projects — Ethan Hammel"
  description="A gallery of projects and artwork."
  page="art"
>

  <div class="art-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb__sep">›</span>
      <span class="breadcrumb__current">Projects &amp; Art</span>
    </nav>

    <h1>Projects &amp; Art</h1>

    <p class="art-lede">
      Personal work — drawings, photographs, experiments, and whatever else
      has felt worth making. Updated as things accumulate.
    </p>

    <ArtGallery items={galleryItems} />
