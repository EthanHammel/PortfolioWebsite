---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
---

<BaseLayout
  title="Page not found — Your Name"
  description="This page doesn't exist."
  page=""
>

  <div style="
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(80px, 14vw, 140px) 24px 80px;
    min-height: 60vh;
  ">

    <!-- Section number style, like nav cards -->
    <span style="
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-light);
      display: block;
      margin-bottom: 20px;
    ">404</span>

    <h1 style="
      font-family: var(--font-display);
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 700;
      color: var(--bark-deep);
      line-height: 1.1;
      margin-bottom: 16px;
    ">This page<br /><em>doesn't exist.</em></h1>

    <p style="
      font-family: var(--font-body);
      font-size: 1rem;
      color: var(--text-mid);
      max-width: 400px;
      line-height: 1.7;
      margin-bottom: 40px;
    ">
      Whatever you were looking for isn't here — it may have moved,
      or the link may be wrong. The home page is a good place to start.
    </p>

    <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
      <a href="/"           class="chip chip--filled">← Back home</a>
      <a href="/resume"     class="chip chip--ghost">Résumé</a>
      <a href="/art"        class="chip chip--ghost">Art</a>
      <a href="/interactive" class="chip chip--ghost">Interactive</a>
    </div>

  </div>

</BaseLayout>
