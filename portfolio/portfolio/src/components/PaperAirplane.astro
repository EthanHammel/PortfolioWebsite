---
// src/components/PaperAirplane.astro
// A small bird that flutters to anchor points and perches there, scrolling with the page.
// Canvas is position:absolute so the bird stays where it landed even on scroll.
// Hidden on mobile < 640px.
---

<canvas id="plane-canvas" aria-hidden="true"></canvas>
<script src="/scripts/bird.js" defer></script>

<style>
  /* Canvas must sit inside a positioned ancestor.
     We set body { position: relative } in global.css already.
     absolute + z-index keeps bird above content but below modals. */
  #plane-canvas {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9000;
    /* width/height set by JS to match full page dimensions */
  }

  @media (max-width: 639px) {
    #plane-canvas { display: none; }
  }
</style>
