---
// src/components/ArtGallery.astro
// Renders the full gallery from a pre-built list of items.
// Pass the galleryItems array from the art page's glob result.
//
// Usage in art.astro:
//   import ArtGallery from '../components/ArtGallery.astro';
//   <ArtGallery items={galleryItems} />

export interface GalleryItem {
  src:      string;
  filename: string;
  ext:      string;
  isGif:    boolean;
  path:     string;
}

export interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

{items.length > 0 ? (
  <div class="gallery" id="gallery">
    {items.map((item) => (
      <div class="gallery-item" data-mobile-tap>
        <img
          src={item.src}
          alt={item.filename.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ')}
          loading="lazy"
          decoding="async"
          width="860"
        />
        <div class="gallery-item__meta">
          <span class="gallery-item__filename">{item.filename}</span>
          <span class="gallery-item__dims">{item.ext.toUpperCase()}{item.isGif ? ' · animated' : ''}</span>
        </div>
      </div>
    ))}
  </div>
) : (
  <div class="gallery-empty">
    <p>Nothing here yet.</p>
    <small>
      Drop image files into <code>/public/art/</code> and rebuild —
      they'll appear here automatically.<br />
      Supported: PNG · JPG · GIF · WEBP
    </small>
  </div>
)}

<script>
  // Mobile: tap to reveal/hide metadata overlay
  document.querySelectorAll('[data-mobile-tap]').forEach(item => {
    item.addEventListener('click', () => {
      if (window.innerWidth < 640) {
        item.classList.toggle('meta-open');
      }
    });
  });
</script>
